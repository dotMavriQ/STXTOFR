STXTOFR_ENV=local
STXTOFR_LOG_LEVEL=INFO
STXTOFR_REPOSITORY_BACKEND=db
STXTOFR_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stxtofr
STXTOFR_ARCHIVE_BACKEND=db
STXTOFR_FILE_ARCHIVE_PATH=./var/raw_payloads
STXTOFR_PUBLISHER_BACKEND=noop
STXTOFR_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
STXTOFR_KAFKA_TOPIC_FACILITIES=stxtofr.facilities
STXTOFR_KAFKA_TOPIC_GAPS=stxtofr.gaps
STXTOFR_BASEROW_BACKEND=noop
STXTOFR_BASEROW_URL=http://127.0.0.1:8080
STXTOFR_BASEROW_VIEW_URL=http://127.0.0.1:8080
STXTOFR_BASEROW_TOKEN=
STXTOFR_BASEROW_TABLE_ID=
STXTOFR_BASEROW_ADMIN_EMAIL=
STXTOFR_BASEROW_ADMIN_PASSWORD=
STXTOFR_EXPORT_SCHEMA_VERSION=stxtofr.facilities.v1
STXTOFR_TRAFIKVERKET_API_URL=https://api.trafikinfo.trafikverket.se/v2/data.json
STXTOFR_TRAFIKVERKET_API_KEY=
STXTOFR_API_KEY=
